ANTHROPIC_API_KEY=
OPENAI_API_KEY=

ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_MODEL=gpt-4o-mini

OLLAMA_MODEL=coder-pro:latest
OLLAMA_FUSION_MODEL=coder-pro:latest
OLLAMA_FUSION_TIMEOUT=45
OLLAMA_API_BASE=http://127.0.0.1:11434

SEMANTIC_ROUTER_EMBEDDINGS=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
SEMANTIC_ROUTER_EMBEDDING_TIMEOUT=2

PLANNING_PROVIDER=auto
PLANNER_MAX_STEPS=8
PLANNER_MAX_TOKENS=1200
PLANNER_USE_CACHE=true
PLANNER_DRY_RUN=false
